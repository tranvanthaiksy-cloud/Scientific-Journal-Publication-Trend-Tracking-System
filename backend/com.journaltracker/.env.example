# Database configuration
DB_URL=jdbc:mysql://localhost:3306/journal_tracker_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password_here

# JWT Security
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# External APIs
OPENALEX_EMAIL=your_email_here

# Sync Scheduler Configuration
SYNC_CRON=0 0 13 * * ?
SYNC_ENABLED=true
SYNC_DEFAULT_QUERY=machine learning
SYNC_MAX_PAGES=10

